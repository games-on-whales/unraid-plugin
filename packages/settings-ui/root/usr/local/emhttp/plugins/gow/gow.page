<?php
// Unraid includes .page files inside the Dynamix shell — do not emit a full HTML document.
global $var;
if (!is_array($var ?? null)) {
    $var = [];
}

function gow_csrf_field() {
    global $var;
    $token = $var['csrf_token'] ?? '';
    echo '<input type="hidden" name="csrf_token" value="' . htmlspecialchars($token, ENT_QUOTES, 'UTF-8') . '">';
}

// Escape a status/error string and keep its line breaks (script output is often
// multi-line). Returns HTML-safe markup.
function gow_msg_html($text) {
    return nl2br(htmlspecialchars(trim((string)$text), ENT_QUOTES, 'UTF-8'));
}

function gow_cfg_line_is_skippable($line) {
    $line = trim($line);
    return $line === '' || $line[0] === '#';
}

define('GOW_CFG',        '/boot/config/plugins/gow/gow.cfg');
define('GOW_SCRIPT_DIR', '/boot/config/plugins/gow/scripts');
define('DEFAULT_CFG',    '/usr/local/emhttp/plugins/gow/default.cfg');
define('DEFAULT_APPDATA','/mnt/user/appdata/gow');
define('DEPLOY_LOG',     '/tmp/gow-deploy.log');
define('UPDATE_LOG',     '/tmp/gow-update.log');
define('LOGS_URL',       '/plugins/gow/php/logs.php');

require_once '/usr/local/emhttp/plugins/gow/php/health-lib.php';

function parse_cfg_lines($path) {
    $cfg = [];
    if (!file_exists($path)) return $cfg;
    foreach (file($path, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (strpos($line, '=') === false || gow_cfg_line_is_skippable($line)) continue;
        [$k, $v] = explode('=', $line, 2);
        $k = trim($k);
        $v = trim($v);
        if (strlen($v) >= 2 && $v[0] === "'" && $v[-1] === "'") {
            $v = str_replace("'\\''", "'", substr($v, 1, -1));
        }
        $cfg[$k] = $v;
    }
    return $cfg;
}

function default_cfg() {
    static $defaults = null;
    if ($defaults !== null) return $defaults;

    $defaults = [
        'APPDATA'           => DEFAULT_APPDATA,
        'RENDER_NODE'       => '',
        'GPU_VENDOR'        => '',
        'GPU_NAME'          => '',
        'GPU_DRIVER'        => '',
        'WOLF_DEN_PORT'     => '8080',
        'WOLF_NETWORK_MODE' => 'host',
        'WOLF_NETWORK_NAME' => '',
        'WOLF_NETWORK_IPV4' => '',
        'STEAM_LIBRARY'     => '/mnt/user/games/steam',
        'GAMES_LIBRARY'     => '/mnt/user/games',
        'ROMS_LIBRARY'      => '/mnt/user/games/roms',
        'BIOS_LIBRARY'      => '/mnt/user/games/bioses',
        'MEDIA_LIBRARY'     => '/mnt/user/games/media',
        'LUTRIS_LIBRARY'    => '/mnt/user/games/lutris',
        'PRISM_LIBRARY'     => '/mnt/user/games/prismlauncher',
        'COMPAT_TOOLS_PATH' => '/mnt/user/appdata/gow/compatibilitytools.d',
        'WOLF_MEMORY_LIMIT'     => '',
        'WOLF_DEN_MEMORY_LIMIT' => '',
        'DEPLOYED'          => 'false',
    ];
    $defaults = array_merge($defaults, parse_cfg_lines(DEFAULT_CFG));
    return $defaults;
}

function load_cfg() {
    $cfg = default_cfg();
    if (!file_exists(GOW_CFG)) return $cfg;
    foreach (file(GOW_CFG, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (strpos($line, '=') === false || gow_cfg_line_is_skippable($line)) continue;
        [$k, $v] = explode('=', $line, 2);
        $k = trim($k);
        $v = trim($v);
        // Strip single quotes added by save_cfg (e.g. GPU_NAME='...')
        if (strlen($v) >= 2 && $v[0] === "'" && $v[-1] === "'") {
            $v = str_replace("'\\''", "'", substr($v, 1, -1));
        }
        $cfg[$k] = $v;
    }
    return $cfg;
}

function save_cfg($cfg) {
    $dir = dirname(GOW_CFG);
    if (!is_dir($dir)) mkdir($dir, 0755, true);
    $order = [
        'APPDATA', 'RENDER_NODE', 'GPU_VENDOR', 'GPU_NAME', 'GPU_DRIVER',
        'WOLF_DEN_PORT', 'WOLF_NETWORK_MODE', 'WOLF_NETWORK_NAME', 'WOLF_NETWORK_IPV4',
        'ROMS_LIBRARY', 'BIOS_LIBRARY', 'STEAM_LIBRARY', 'GAMES_LIBRARY',
        'MEDIA_LIBRARY', 'LUTRIS_LIBRARY', 'PRISM_LIBRARY', 'COMPAT_TOOLS_PATH',
        'WOLF_IMAGE', 'WOLF_DEN_IMAGE', 'WOLF_ENCODER_NODE',
        'WOLF_MEMORY_LIMIT', 'WOLF_DEN_MEMORY_LIMIT',
        'DEPLOYED',
    ];
    $out = '';
    foreach ($order as $k) {
        if (!array_key_exists($k, $cfg)) {
            continue;
        }
        $v = $cfg[$k];
        $quoted = "'" . str_replace("'", "'\\''", $v) . "'";
        $out .= "$k=$quoted\n";
    }
    foreach ($cfg as $k => $v) {
        if (in_array($k, $order, true)) {
            continue;
        }
        $quoted = "'" . str_replace("'", "'\\''", $v) . "'";
        $out .= "$k=$quoted\n";
    }
    file_put_contents(GOW_CFG, $out);
}

function gow_games_share_root(array $cfg) {
    $games = rtrim($cfg['GAMES_LIBRARY'] ?? '', '/');
    if ($games !== '') {
        return $games;
    }
    $found = discover_existing_path(['/mnt/user/games', '/mnt/user/Games']);
    return $found !== '' ? $found : '/mnt/user/games';
}

function gow_apply_standard_library_paths($games_root, array &$cfg) {
    $games_root = rtrim($games_root, '/');
    if ($games_root === '') {
        return false;
    }
    $appdata = rtrim($cfg['APPDATA'] ?? DEFAULT_APPDATA, '/');
    $cfg['GAMES_LIBRARY'] = $games_root;
    $cfg['ROMS_LIBRARY'] = $games_root . '/roms';
    $cfg['BIOS_LIBRARY'] = $games_root . '/bioses';
    $cfg['STEAM_LIBRARY'] = $games_root . '/steam';
    $cfg['LUTRIS_LIBRARY'] = $games_root . '/lutris';
    $cfg['PRISM_LIBRARY'] = $games_root . '/prismlauncher';
    $cfg['MEDIA_LIBRARY'] = $games_root . '/media';
    if ($appdata !== '') {
        $cfg['COMPAT_TOOLS_PATH'] = $appdata . '/compatibilitytools.d';
    }
    return true;
}

function gow_read_library_paths_from_post(array &$cfg) {
    $cfg['STEAM_LIBRARY']     = normalize_optional_path($_POST['steam_library'] ?? '');
    $cfg['GAMES_LIBRARY']     = normalize_optional_path($_POST['games_library'] ?? '');
    $cfg['ROMS_LIBRARY']      = normalize_optional_path($_POST['roms_library'] ?? '');
    $cfg['BIOS_LIBRARY']      = normalize_optional_path($_POST['bios_library'] ?? '');
    $cfg['MEDIA_LIBRARY']     = normalize_optional_path($_POST['media_library'] ?? '');
    $cfg['LUTRIS_LIBRARY']    = normalize_optional_path($_POST['lutris_library'] ?? '');
    $cfg['PRISM_LIBRARY']     = normalize_optional_path($_POST['prism_library'] ?? '');
    $cfg['COMPAT_TOOLS_PATH'] = normalize_optional_path($_POST['compat_tools_path'] ?? '');
}

function gow_validate_setup_paths(array $cfg) {
    if (!valid_host_path($cfg['APPDATA'], true)) {
        return 'Appdata path must be an absolute path under /mnt/.';
    }
    foreach ([
        'STEAM_LIBRARY' => 'Steam library',
        'GAMES_LIBRARY' => 'Games library',
        'ROMS_LIBRARY' => 'ROMs library',
        'BIOS_LIBRARY' => 'BIOS files path',
        'MEDIA_LIBRARY' => 'Media library',
        'LUTRIS_LIBRARY' => 'Lutris data path',
        'PRISM_LIBRARY' => 'Prism Launcher data path',
        'COMPAT_TOOLS_PATH' => 'Compatibility tools path',
    ] as $key => $label) {
        if (!valid_host_path($cfg[$key] ?? '')) {
            return "{$label} must be empty or an absolute path under /mnt/.";
        }
    }
    return '';
}

function pick_root() {
    // Prefer /mnt/ so folder browse can reach both user and cache pools.
    if (is_dir('/mnt/user/') || is_dir('/mnt/cache/')) {
        return '/mnt/';
    }
    return '/mnt/';
}

/** @return list<array{root:string,label:string,name:string}> */
function unraid_share_entries() {
    $entries = [];
    foreach (['user' => '/mnt/user', 'cache' => '/mnt/cache'] as $label => $root) {
        if (!is_dir($root)) {
            continue;
        }
        foreach (scandir($root) ?: [] as $entry) {
            if ($entry === '.' || $entry === '..') {
                continue;
            }
            if (!is_dir($root . '/' . $entry)) {
                continue;
            }
            $entries[] = [
                'root'  => $root,
                'label' => $label,
                'name'  => $entry,
            ];
        }
    }
    usort($entries, static function ($a, $b) {
        $cmp = strnatcasecmp($a['label'], $b['label']);
        return $cmp !== 0 ? $cmp : strnatcasecmp($a['name'], $b['name']);
    });
    return $entries;
}

function gow_path_picker_attrs($pick_root) {
    $root = htmlspecialchars(rtrim($pick_root, '/') . '/', ENT_QUOTES, 'UTF-8');
    return 'autocomplete="off" spellcheck="false" '
         . 'data-pickfolders="true" data-pickfilter="HIDE_FILES_FILTER" '
         . 'data-pickcloseonfile="true" '
         . 'data-pickroot="' . $root . '" data-picktop="' . $root . '"';
}

function valid_host_path($path, $required = false) {
    $path = rtrim(trim($path), '/');
    if ($path === '') return !$required;
    if ($path[0] !== '/') return false;
    if (strpos($path, '..') !== false) return false;
    return strncmp($path, '/mnt/', 5) === 0;
}

function normalize_optional_path($path) {
    $path = rtrim(trim($path), '/');
    return $path === '' ? '' : $path;
}

function discover_existing_path(array $candidates) {
    foreach ($candidates as $path) {
        if (is_dir($path)) {
            return rtrim($path, '/');
        }
    }
    return '';
}

function smart_path_map() {
    // Keep in sync with scripts/detect-paths.sh candidate lists.
    return [
        'APPDATA' => ['/mnt/user/appdata/gow', '/mnt/cache/appdata/gow'],
        'ROMS_LIBRARY' => [
            '/mnt/user/games/roms', '/mnt/user/roms', '/mnt/user/ROMs', '/mnt/user/retrogaming/roms',
            '/mnt/cache/games/roms', '/mnt/cache/roms', '/mnt/cache/ROMs',
        ],
        'BIOS_LIBRARY' => [
            '/mnt/user/games/bioses', '/mnt/user/bioses', '/mnt/user/bios', '/mnt/user/retrogaming/bios',
            '/mnt/cache/games/bioses', '/mnt/cache/bioses',
        ],
        'STEAM_LIBRARY' => ['/mnt/user/games/steam', '/mnt/user/steam', '/mnt/cache/steam'],
        'GAMES_LIBRARY' => ['/mnt/user/games', '/mnt/user/Games', '/mnt/cache/games'],
        'MEDIA_LIBRARY' => [
            '/mnt/user/games/media', '/mnt/user/media', '/mnt/user/Media', '/mnt/cache/games/media',
        ],
        'LUTRIS_LIBRARY' => [
            '/mnt/user/games/lutris', '/mnt/user/appdata/gow/lutris', '/mnt/user/appdata/lutris',
            '/mnt/cache/appdata/gow/lutris',
        ],
        'PRISM_LIBRARY' => [
            '/mnt/user/games/prismlauncher', '/mnt/user/appdata/gow/prismlauncher',
            '/mnt/cache/games/prismlauncher', '/mnt/cache/appdata/gow/prismlauncher',
        ],
        'COMPAT_TOOLS_PATH' => [
            '/mnt/user/appdata/gow/compatibilitytools.d', '/mnt/cache/appdata/gow/compatibilitytools.d',
        ],
    ];
}

function apply_smart_path_defaults(array &$cfg) {
    $changed = [];
    foreach (smart_path_map() as $key => $candidates) {
        $current = rtrim($cfg[$key] ?? '', '/');
        if ($current !== '' && is_dir($current)) {
            continue;
        }
        $found = discover_existing_path($candidates);
        if ($found !== '' && $found !== $current) {
            $cfg[$key] = $found;
            $changed[$key] = $found;
        }
    }
    return $changed;
}

function path_status_label($path) {
    $path = rtrim(trim($path), '/');
    if ($path === '') {
        return '';
    }
    if (is_dir($path)) {
        return 'exists';
    }
    $parent = dirname($path);
    if (is_dir($parent)) {
        return 'will create';
    }
    return 'missing parent';
}

function gow_path_field($id, $name, $label, $value, $pick_root, $help = '') {
    static $share_entries = null;
    if ($share_entries === null) {
        $share_entries = unraid_share_entries();
    }
    $status = path_status_label($value);
    $status_html = '';
    if ($status === 'exists') {
        $status_html = '<span class="gow-path-status ok">Found on disk</span>';
    } elseif ($status === 'will create') {
        $status_html = '<span class="gow-path-status warn">Created on install</span>';
    } elseif ($status === 'missing parent') {
        $status_html = '<span class="gow-path-status err">Parent share missing</span>';
    }
    ?>
    <div class="gow-field">
      <label class="gow-label" for="<?= htmlspecialchars($id) ?>"><?= htmlspecialchars($label) ?></label>
      <div class="gow-path-row">
        <?php if (!empty($share_entries)): ?>
        <select class="gow-select gow-share-select" data-target="<?= htmlspecialchars($id) ?>"
                aria-label="Jump to Unraid share for <?= htmlspecialchars($label) ?>">
          <option value="">Share…</option>
          <?php foreach ($share_entries as $entry): ?>
            <?php
              $share_path = $entry['root'] . '/' . $entry['name'];
              $share_label = $entry['label'] . '/' . $entry['name'];
            ?>
            <option value="<?= htmlspecialchars($share_path) ?>"><?= htmlspecialchars($share_label) ?></option>
          <?php endforeach; ?>
        </select>
        <?php endif; ?>
        <input type="text" name="<?= htmlspecialchars($name) ?>" id="<?= htmlspecialchars($id) ?>"
               class="gow-input gow-path-picker"
               value="<?= htmlspecialchars($value) ?>"
               placeholder="Click Browse or type a path…"
               <?= gow_path_picker_attrs($pick_root) ?>>
        <button type="button" class="gow-btn gow-btn-secondary gow-browse-btn"
                title="Browse folders" aria-label="Browse folders for <?= htmlspecialchars($label) ?>"
                data-target="<?= htmlspecialchars($id) ?>">Browse</button>
      </div>
      <?php if ($help !== ''): ?><p class="gow-help"><?= htmlspecialchars($help) ?></p><?php endif; ?>
      <?= $status_html ?>
    </div>
    <?php
}

function gow_render_health_card(?array $health, array $opts = []) {
    if ($health === null) {
        return;
    }
    $deployed = !empty($opts['deployed']);
    $summary = $health['summary'] ?? 'unknown';
    $title = $deployed ? 'Health check' : 'Pre-install check';
    ?>
<div class="gow-card" id="gow-health-card">
  <div class="gow-health-toolbar">
    <div class="gow-title" style="margin:0;border:none;padding:0;flex:1"><?= htmlspecialchars($title) ?></div>
    <span class="gow-health-badge <?= htmlspecialchars($summary) ?>"><?= htmlspecialchars($summary) ?></span>
  </div>
  <ul class="gow-health-list" id="gow-health-list">
    <?php foreach ($health['checks'] ?? [] as $check): ?>
      <li class="level-<?= htmlspecialchars($check['level']) ?>">
        <?php
          $icon = $check['level'] === 'ok' ? '✓' : ($check['level'] === 'fail' ? '✗' : '!');
          echo htmlspecialchars("{$icon} {$check['label']}");
        ?>
        <?php if (!empty($check['hint'])): ?>
          <div class="hint"><?= htmlspecialchars($check['hint']) ?></div>
        <?php endif; ?>
      </li>
    <?php endforeach; ?>
  </ul>
  <?php if (!$deployed): ?>
  <p class="gow-section-note">Fix failed items before Install.</p>
  <?php endif; ?>
</div>
    <?php
}

function gow_library_slot_map() {
    return [
        'ROMs' => ['key' => 'ROMS_LIBRARY', 'slot' => 'roms'],
        'BIOS' => ['key' => 'BIOS_LIBRARY', 'slot' => 'bioses'],
        'Steam' => ['key' => 'STEAM_LIBRARY', 'slot' => 'steam'],
        'Games' => ['key' => 'GAMES_LIBRARY', 'slot' => 'games'],
        'Lutris' => ['key' => 'LUTRIS_LIBRARY', 'slot' => 'lutris'],
        'Prism Launcher' => ['key' => 'PRISM_LIBRARY', 'slot' => 'prismlauncher'],
        'Media' => ['key' => 'MEDIA_LIBRARY', 'slot' => 'media'],
        'Compat tools' => ['key' => 'COMPAT_TOOLS_PATH', 'slot' => 'compatibilitytools.d'],
    ];
}

function gow_library_mount_display($appdata, $slot, $configured) {
    $configured = rtrim(trim($configured), '/');
    if ($configured === '') {
        return '';
    }
    $canonical = rtrim($appdata, '/') . '/' . $slot;
    if ($configured === $canonical) {
        return $canonical;
    }
    if (is_link($canonical)) {
        $target = readlink($canonical);
        if ($target !== false && $target !== '') {
            return $canonical . ' → ' . $target;
        }
    }
    return $configured;
}

function library_mount_summary($cfg) {
    $appdata = rtrim($cfg['APPDATA'] ?? DEFAULT_APPDATA, '/');
    $active = [];
    foreach (gow_library_slot_map() as $label => $meta) {
        $path = $cfg[$meta['key']] ?? '';
        if ($path === '') {
            continue;
        }
        $active[] = [$label, gow_library_mount_display($appdata, $meta['slot'], $path)];
    }
    return $active;
}

function network_summary($mode, $name, $ipv4) {
    if ($mode === 'custom') {
        $label = $name !== '' ? $name : 'custom network';
        if ($ipv4 !== '') $label .= " · {$ipv4}";
        return $label;
    }
    return ucfirst($mode);
}

function wolf_cfg_dir($appdata) {
    return rtrim($appdata, '/') . '/cfg';
}

function count_paired_clients($appdata) {
    $cfg_file = wolf_cfg_dir($appdata) . '/config.toml';
    if (!is_readable($cfg_file)) {
        return null;
    }
    $text = file_get_contents($cfg_file);
    if ($text === false) {
        return null;
    }
    if (!preg_match_all('/^\[\[paired_clients\]\]/m', $text, $matches)) {
        return 0;
    }
    return count($matches[0]);
}

function wolf_pairing_identity_ok($appdata) {
    $dir = wolf_cfg_dir($appdata);
    return is_file("{$dir}/config.toml")
        && is_file("{$dir}/key.pem")
        && is_file("{$dir}/cert.pem");
}

function pairing_status_label($appdata) {
    if (!wolf_pairing_identity_ok($appdata)) {
        return 'Not ready — pair after Wolf finishes starting';
    }
    $count = count_paired_clients($appdata);
    if ($count === null) {
        return 'Ready';
    }
    if ($count === 0) {
        return 'Ready — no clients paired yet';
    }
    if ($count === 1) {
        return '1 Moonlight client paired';
    }
    return "{$count} Moonlight clients paired";
}

// ── GPU detection ─────────────────────────────────────────────────────────────

function detect_gpus() {
    $gpus = [];
    $nodes = glob('/sys/class/drm/renderD*/device/driver') ?: [];
    foreach ($nodes as $driver_path) {
        $device_dir  = dirname($driver_path);
        $render_name = basename(dirname($device_dir));
        $render_node = "/dev/dri/{$render_name}";

        $link = is_link($driver_path) ? readlink($driver_path) : false;
        $driver = ($link !== false && $link !== '') ? basename($link) : 'unknown';
        $vendor_map = ['i915' => 'Intel', 'xe' => 'Intel', 'amdgpu' => 'AMD', 'nvidia' => 'NVIDIA'];
        $vendor = $vendor_map[$driver] ?? "Unknown ($driver)";

        $name = 'Unknown';
        $pci_slot = '';
        $real_path = realpath($device_dir);
        if ($real_path) $pci_slot = basename($real_path);
        if ($pci_slot) {
            $lspci_out = [];
            exec("lspci -s " . escapeshellarg($pci_slot) . " -mm 2>/dev/null", $lspci_out);
            if (!empty($lspci_out[0])) {
                // Format: "Slot" "Class" "Vendor" "Device" ...
                $parts = str_getcsv($lspci_out[0], ' ', '"');
                if (isset($parts[3])) $name = $parts[3];
            }
        }

        $gpus[] = [
            'node'   => $render_node,
            'driver' => $driver,
            'vendor' => $vendor,
            'name'   => $name,
            'label'  => "$vendor $name ($render_node)",
        ];
    }
    return $gpus;
}

// ── Container status ──────────────────────────────────────────────────────────

function container_status($name) {
    exec("docker inspect --format '{{.State.Status}}' " . escapeshellarg($name) . " 2>/dev/null", $out, $ret);
    return ($ret === 0 && !empty($out[0])) ? $out[0] : 'not found';
}

function container_oom_killed($name) {
    exec("docker inspect --format '{{.State.OOMKilled}}' " . escapeshellarg($name) . " 2>/dev/null", $out, $ret);
    return $ret === 0 && (($out[0] ?? '') === 'true');
}

function count_stale_wolf_sessions() {
    exec('docker ps -a --filter "status=exited" --format "{{.Names}}" 2>/dev/null', $out);
    $count = 0;
    foreach ($out as $name) {
        $name = ltrim(trim($name), '/');
        if ($name === '' || $name === 'wolf' || $name === 'wolf-den') {
            continue;
        }
        if (strncmp($name, 'Wolf', 4) === 0) {
            $count++;
        }
    }
    return $count;
}

function valid_memory_limit($limit) {
    $limit = trim($limit);
    if ($limit === '') return true;
    return (bool)preg_match('/^[0-9]+[bkmgBKMG]?$/', $limit);
}

function host_memory_gib() {
    $kb = 0;
    if (is_readable('/proc/meminfo')) {
        foreach (file('/proc/meminfo', FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
            if (strpos($line, 'MemTotal:') === 0) {
                $kb = (int)preg_replace('/\D/', '', $line);
                break;
            }
        }
    }
    return $kb > 0 ? (int)round($kb / 1024 / 1024) : null;
}

function status_badge($status) {
    $map = [
        'running'    => ['running',    '● Running'],
        'exited'     => ['stopped',    '● Stopped'],
        'restarting' => ['restarting', '● Restarting'],
        'not found'  => ['unknown',    '○ Not deployed'],
    ];
    [$cls, $label] = $map[$status] ?? ['unknown', "○ $status"];
    return "<span class='gow-status-{$cls}'>" . htmlspecialchars($label) . "</span>";
}

function local_ip() {
    exec("hostname -I 2>/dev/null", $out);
    return trim(explode(' ', $out[0] ?? '')[0]);
}

function docker_networks() {
    $networks = [];
    exec("docker network ls --format '{{.Name}}' 2>/dev/null", $out);
    foreach ($out as $name) {
        $name = trim($name);
        if ($name !== '' && preg_match('/^[A-Za-z0-9_.-]+$/', $name)) {
            $networks[] = $name;
        }
    }
    return array_values(array_unique($networks));
}

function valid_tcp_port($port) {
    return is_string($port) && preg_match('/^[0-9]+$/', $port)
        && (int)$port >= 1 && (int)$port <= 65535;
}

function cleanup_wolf_runtime_containers() {
    exec('docker rm -f WolfPulseAudio >/dev/null 2>&1 || true');
}

function cleanup_stale_wolf_sessions() {
    $script = GOW_SCRIPT_DIR . '/cleanup-wolf-sessions.sh';
    if (!is_executable($script)) return;
    exec('bash ' . escapeshellarg($script) . ' 2>&1', $out, $ret);
}

function valid_network_mode($mode) {
    return in_array($mode, ['host', 'bridge', 'custom'], true);
}

function valid_network_name($name) {
    return is_string($name) && preg_match('/^[A-Za-z0-9_.-]+$/', $name);
}

function valid_ipv4($ip) {
    if (!is_string($ip) || !preg_match('/^(\d{1,3}\.){3}\d{1,3}$/', $ip)) return false;
    foreach (explode('.', $ip) as $part) {
        if ((int)$part < 0 || (int)$part > 255 || (string)(int)$part !== (string)$part) return false;
    }
    return true;
}

// Wolf composes through Wayland; on NVIDIA this requires nvidia_drm.modeset=Y
// or the client gets a black screen. See docs/FAQ.md.
function nvidia_drm_modeset_ok() {
    $path = '/sys/module/nvidia_drm/parameters/modeset';
    if (!is_readable($path)) return false;
    return trim(@file_get_contents($path)) === 'Y';
}

function has_mdns_conflict() {
    exec("ss -H -ulpn 2>/dev/null", $out);
    $has_avahi = false;
    $has_wolf = false;
    foreach ($out as $line) {
        if (strpos($line, ':5353') === false) continue;
        if (strpos($line, 'avahi-daemon') !== false) $has_avahi = true;
        if (strpos($line, '"wolf"') !== false || strpos($line, 'users:((wolf,') !== false) $has_wolf = true;
    }
    return $has_avahi && $has_wolf;
}

define('FAQ_MODESET_URL', 'https://github.com/games-on-whales/unraid-plugin/blob/main/docs/FAQ.md#nvidia-wayland-support-nvidia_drmmodeset');
define('FAQ_MDNS_URL', 'https://github.com/games-on-whales/unraid-plugin/blob/main/docs/FAQ.md#moonlight-discovery-and-mdnsavahi-warnings');
define('FAQ_OOM_URL', 'https://github.com/games-on-whales/unraid-plugin/blob/main/docs/FAQ.md#out-of-memory-oom-crashes');
define('WOLF_DEN_PAIRING_PATH', '/Clients/Pairing');

// ── Action handlers ───────────────────────────────────────────────────────────

$cfg     = load_cfg();
$message = '';
$error   = '';
$force_setup = false;

if ($_SERVER['REQUEST_METHOD'] !== 'POST' && (($cfg['DEPLOYED'] ?? 'false') !== 'true' || isset($_GET['setup']))) {
    apply_smart_path_defaults($cfg);
    $games_share_root = gow_games_share_root($cfg);
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $action = $_POST['action'] ?? '';

    if ($action === 'apply_games_layout' || $action === 'save_settings' || $action === 'save_and_deploy') {
        $cfg['RENDER_NODE'] = $_POST['render_node'] ?? $cfg['RENDER_NODE'];
        $cfg['APPDATA']     = rtrim($_POST['appdata'] ?? $cfg['APPDATA'] ?? DEFAULT_APPDATA, '/');
        $cfg['WOLF_DEN_PORT'] = trim($_POST['wolf_den_port'] ?? $cfg['WOLF_DEN_PORT'] ?? '8080');
        $cfg['WOLF_NETWORK_MODE'] = $_POST['wolf_network_mode'] ?? $cfg['WOLF_NETWORK_MODE'] ?? 'host';
        $cfg['WOLF_NETWORK_NAME'] = trim($_POST['wolf_network_name'] ?? $cfg['WOLF_NETWORK_NAME'] ?? '');
        $cfg['WOLF_NETWORK_IPV4'] = trim($_POST['wolf_network_ipv4'] ?? $cfg['WOLF_NETWORK_IPV4'] ?? '');
        gow_read_library_paths_from_post($cfg);
        if ($action === 'apply_games_layout') {
            gow_apply_standard_library_paths(gow_games_share_root($cfg), $cfg);
        }
        $cfg['WOLF_MEMORY_LIMIT'] = strtoupper(trim($_POST['wolf_memory_limit'] ?? $cfg['WOLF_MEMORY_LIMIT'] ?? ''));
        $cfg['WOLF_DEN_MEMORY_LIMIT'] = strtoupper(trim($_POST['wolf_den_memory_limit'] ?? $cfg['WOLF_DEN_MEMORY_LIMIT'] ?? ''));

        $gpus = detect_gpus();
        foreach ($gpus as $gpu) {
            if ($gpu['node'] === $cfg['RENDER_NODE']) {
                $cfg['GPU_VENDOR'] = $gpu['vendor'];
                $cfg['GPU_NAME']   = $gpu['name'];
                $cfg['GPU_DRIVER'] = $gpu['driver'];
                break;
            }
        }

        if (empty($cfg['RENDER_NODE'])) {
            $error = 'Please select a GPU.';
        } elseif (empty($cfg['GPU_VENDOR'])) {
            $error = 'Selected GPU not recognised. Please refresh and try again.';
        } elseif (!valid_tcp_port($cfg['WOLF_DEN_PORT'])) {
            $error = 'Wolf Den port must be a TCP port between 1 and 65535.';
        } elseif (!valid_network_mode($cfg['WOLF_NETWORK_MODE'])) {
            $error = 'Wolf network mode must be Host, Bridge, or Custom network.';
        } elseif ($cfg['WOLF_NETWORK_MODE'] === 'custom' && !valid_network_name($cfg['WOLF_NETWORK_NAME'])) {
            $error = 'Custom Wolf network requires a Docker network name such as br0.';
        } elseif ($cfg['WOLF_NETWORK_MODE'] === 'custom' && $cfg['WOLF_NETWORK_IPV4'] === '') {
            $error = 'Custom Wolf network requires a static IPv4 address.';
        } elseif ($cfg['WOLF_NETWORK_MODE'] === 'custom' && !valid_ipv4($cfg['WOLF_NETWORK_IPV4'])) {
            $error = 'Wolf static IPv4 address is invalid.';
        } elseif (($path_err = gow_validate_setup_paths($cfg)) !== '') {
            $error = $path_err;
        } elseif (!valid_memory_limit($cfg['WOLF_MEMORY_LIMIT'])) {
            $error = 'Wolf memory limit must be empty or like 6G / 8192M.';
        } elseif (!valid_memory_limit($cfg['WOLF_DEN_MEMORY_LIMIT'])) {
            $error = 'Wolf Den memory limit must be empty or like 512M.';
        } else {
            if ($action === 'save_settings') {
                $cfg['DEPLOYED'] = 'true';
            }
            save_cfg($cfg);
            if ($action === 'apply_games_layout') {
                $message = 'Standard library folders set under ' . gow_games_share_root($cfg) . '. Review paths below, then Install or Save.';
                $force_setup = true;
            } elseif ($action === 'save_settings') {
                if (file_exists(GOW_SCRIPT_DIR . '/apply-mount-presets.sh')) {
                    exec('bash ' . escapeshellarg(GOW_SCRIPT_DIR . '/apply-mount-presets.sh') . ' 2>&1', $preset_out, $preset_ret);
                }
                echo '<script>window.location.href = window.location.pathname + "?saved=1";</script>';
                exit;
            } else {
                @unlink(DEPLOY_LOG);
                $deploy_script = GOW_SCRIPT_DIR . '/deploy.sh';
                $deploy_cmd = 'if command -v stdbuf >/dev/null 2>&1; then '
                    . 'stdbuf -oL -eL bash ' . escapeshellarg($deploy_script)
                    . '; else bash ' . escapeshellarg($deploy_script) . '; fi';
                exec($deploy_cmd . ' > ' . DEPLOY_LOG . ' 2>&1 < /dev/null &');
                echo '<script>window.location.href = window.location.pathname + "?deploying=1";</script>';
                exit;
            }
        }
        if ($error !== '') {
            $force_setup = true;
        }

    } elseif ($action === 'start') {
        $compose = $cfg['APPDATA'] . '/docker-compose.yml';
        if (file_exists($compose)) {
            exec("docker compose -f " . escapeshellarg($compose) . " up -d 2>&1", $out, $ret);
        } else {
            exec("docker start wolf wolf-den 2>&1", $out, $ret);
        }
        $message = $ret === 0 ? 'Wolf started.' : 'Start failed: ' . implode("\n", $out);

    } elseif ($action === 'stop') {
        $compose = $cfg['APPDATA'] . '/docker-compose.yml';
        if (file_exists($compose)) {
            exec("docker compose -f " . escapeshellarg($compose) . " down 2>&1", $out, $ret);
        } else {
            exec("docker stop wolf-den wolf 2>&1", $out, $ret);
        }
        cleanup_wolf_runtime_containers();
        cleanup_stale_wolf_sessions();
        $message = $ret === 0 ? 'Wolf stopped.' : 'Stop failed: ' . implode("\n", $out);

    } elseif ($action === 'cleanup_sessions') {
        exec('bash ' . GOW_SCRIPT_DIR . '/cleanup-wolf-sessions.sh 2>&1', $out, $ret);
        $message = $ret === 0
            ? implode("\n", $out)
            : 'Cleanup failed: ' . implode("\n", $out);

    } elseif ($action === 'update') {
        @unlink(UPDATE_LOG);
        $update_script = GOW_SCRIPT_DIR . '/update.sh';
        $update_cmd = 'if command -v stdbuf >/dev/null 2>&1; then '
            . 'stdbuf -oL -eL bash ' . escapeshellarg($update_script)
            . '; else bash ' . escapeshellarg($update_script) . '; fi';
        exec($update_cmd . ' > ' . UPDATE_LOG . ' 2>&1 < /dev/null &');
        echo '<script>window.location.href = window.location.pathname + "?updating=1";</script>';
        exit;

    } elseif ($action === 'reset_defaults') {
        exec('bash ' . GOW_SCRIPT_DIR . '/reset.sh 2>&1', $out, $ret);
        if ($ret === 0) {
            echo '<script>window.location.href = window.location.pathname + "?setup=1&reset=1";</script>';
            exit;
        }
        $error = 'Reset failed: ' . implode("\n", $out);

    } elseif ($action === 'repair_esde') {
        exec('bash ' . GOW_SCRIPT_DIR . '/repair-esde.sh 2>&1', $out, $ret);
        $message = $ret === 0
            ? "ES-DE repair finished:\n" . implode("\n", $out)
            : 'ES-DE repair failed: ' . implode("\n", $out);

    } elseif ($action === 'fix_all') {
        exec('bash ' . GOW_SCRIPT_DIR . '/fix-all.sh 2>&1', $out, $ret);
        if ($ret === 0) {
            echo '<script>window.location.href = window.location.pathname + "?fixed=1";</script>';
            exit;
        }
        $error = 'Fix-all failed: ' . implode("\n", $out);

    } elseif ($action === 'reconfigure') {
        $cfg['DEPLOYED'] = 'false';
        save_cfg($cfg);
        echo '<script>window.location.href = window.location.pathname + "?setup=1";</script>';
        exit;
    }
}

// Detect if a deploy or update is in progress
$deploying = isset($_GET['deploying']);
$updating  = isset($_GET['updating']);
if ($deploying) {
    exec("pgrep -f " . escapeshellarg(GOW_SCRIPT_DIR . '/deploy.sh'), $pids);
    if (empty($pids)) {
        $cfg = load_cfg();
        $deploying = false;
    }
}
if ($updating) {
    exec("pgrep -f " . escapeshellarg(GOW_SCRIPT_DIR . '/update.sh'), $pids);
    if (empty($pids)) {
        $updating = false;
        $message = 'Update complete.';
    }
}

$gpus            = detect_gpus();
$docker_networks = docker_networks();
$ip              = local_ip();
$wolf_status     = container_status('wolf');
$wolf_den_status = container_status('wolf-den');
$compose_file    = $cfg['APPDATA'] . '/docker-compose.yml';
$has_stack       = file_exists($compose_file) || $wolf_status !== 'not found' || $wolf_den_status !== 'not found';
$setup_mode      = $force_setup || isset($_GET['setup']);
$reconfigure_mode = $setup_mode && $has_stack;
$deployed        = !$setup_mode && (($cfg['DEPLOYED'] === 'true') || $has_stack);
$games_share_root = gow_games_share_root($cfg);
$wolf_den_port   = valid_tcp_port($cfg['WOLF_DEN_PORT']) ? $cfg['WOLF_DEN_PORT'] : '8080';
$wolf_den_url    = $ip ? "http://{$ip}:{$wolf_den_port}" : '';
$pairing_url     = $wolf_den_url ? $wolf_den_url . WOLF_DEN_PAIRING_PATH : '';

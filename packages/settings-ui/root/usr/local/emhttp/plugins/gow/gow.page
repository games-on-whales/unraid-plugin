    <div class="gow-row gow-network-custom" style="flex-direction:column;align-items:flex-start;gap:6px;margin-top:10px">
      <label class="gow-label" for="wolf_network_name">Docker network / interface</label>
      <input type="text" name="wolf_network_name" id="wolf_network_name" class="gow-input"
             value="<?= htmlspecialchars($wolf_network_name) ?>"
             list="gow_networks"
             placeholder="br0">
      <datalist id="gow_networks">
        <?php foreach ($docker_networks as $network): ?>
          <option value="<?= htmlspecialchars($network) ?>"></option>
        <?php endforeach; ?>
      </datalist>
    </div>

    <div class="gow-row gow-network-custom" style="flex-direction:column;align-items:flex-start;gap:6px;margin-top:10px">
      <label class="gow-label" for="wolf_network_ipv4">Wolf static IPv4</label>
      <input type="text" name="wolf_network_ipv4" id="wolf_network_ipv4" class="gow-input"
             value="<?= htmlspecialchars($wolf_network_ipv4) ?>"
             placeholder="192.168.1.50">
    </div>

    <?php if ($cfg['GPU_VENDOR'] === 'NVIDIA'): ?>
    <p class="gow-warn">
      ⚠ NVIDIA GPU selected. On first install, a driver volume will be built — this can take
      5–10 minutes. The page will show progress while it runs.
    </p>
    <?php endif; ?>

    <?php
      $has_nvidia = false;
      foreach ($gpus as $g) { if ($g['vendor'] === 'NVIDIA') { $has_nvidia = true; break; } }
    ?>
    <?php if ($has_nvidia && !nvidia_drm_modeset_ok()): ?>
    <p class="gow-error">
      ⚠ NVIDIA detected but <code>nvidia_drm.modeset</code> is not enabled. Wolf's
      Wayland compositor will not work until you set it. Open
      <strong>Tools &gt; System Drivers</strong>, edit <code>nvidia_drm</code>,
      set the Modprobe.d Config File to <code>options nvidia_drm modeset=1</code>,
      apply, and reboot before installing.
      <a href="<?= FAQ_MODESET_URL ?>" target="_blank" class="gow-msg-link">Details</a>.
    </p>
    <?php endif; ?>

    <div class="gow-actions" style="margin-top:16px">
      <?php if (!empty($gpus)): ?>
        <button type="submit" class="gow-btn gow-btn-primary">Install</button>
      <?php endif; ?>
    </div>
  </form>
</div>

<?php endif; ?>

</div>
<script>
(() => {
  const mode = document.getElementById('wolf_network_mode');
  const customRows = document.querySelectorAll('.gow-network-custom');
  if (!mode) return;

  const syncNetworkFields = () => {
    const show = mode.value === 'custom';
    customRows.forEach(row => { row.style.display = show ? 'flex' : 'none'; });
  };

  mode.addEventListener('change', syncNetworkFields);
  syncNetworkFields();
})();
</script>
</body>
</html>

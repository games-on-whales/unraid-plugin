$wolf_network_name = $cfg['WOLF_NETWORK_NAME'];
$wolf_network_ipv4 = $cfg['WOLF_NETWORK_IPV4'];
$moonlight_host    = ($wolf_network_mode === 'custom' && valid_ipv4($wolf_network_ipv4)) ? $wolf_network_ipv4 : $ip;
$mdns_conflict   = $deployed && has_mdns_conflict();
$pick_root       = pick_root();
$reset_notice    = isset($_GET['reset']);
$deploy_error    = isset($_GET['deploy_error']);
$library_mounts  = library_mount_summary($cfg);
$network_open    = ($wolf_network_mode === 'custom');
$pairing_status  = pairing_status_label($cfg['APPDATA']);
$wolf_oom_killed   = container_oom_killed('wolf');
$stale_sessions    = count_stale_wolf_sessions();
$host_memory_gib   = host_memory_gib();
$welcome_notice    = isset($_GET['welcome']);
$library_open      = !$has_stack;
$health            = $deployed ? gow_run_health_checks($cfg) : gow_run_setup_health_checks($cfg, $gpus);
$health_summary    = $health['summary'] ?? '';
$install_ready     = gow_health_ready($health);
$fixed_notice      = isset($_GET['fixed']);
$saved_notice      = isset($_GET['saved']);

<?php
// ── Config ────────────────────────────────────────────────────────────────────

define('GOW_CFG',        '/boot/config/plugins/gow/gow.cfg');
define('GOW_SCRIPT_DIR', '/boot/config/plugins/gow/scripts');
define('DEFAULT_APPDATA','/mnt/user/appdata/gow');
define('DEPLOY_LOG',     '/tmp/gow-deploy.log');

function load_cfg() {
    $cfg = [
        'APPDATA'     => DEFAULT_APPDATA,
        'RENDER_NODE' => '',
        'GPU_VENDOR'  => '',
        'GPU_NAME'    => '',
        'GPU_DRIVER'  => '',
        'WOLF_DEN_PORT' => '8080',
        'WOLF_NETWORK_MODE' => 'host',
        'WOLF_NETWORK_NAME' => '',
        'WOLF_NETWORK_IPV4' => '',
        'DEPLOYED'    => 'false',
    ];
    if (!file_exists(GOW_CFG)) return $cfg;
    foreach (file(GOW_CFG, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
        if (strpos($line, '=') === false || $line[0] === '#') continue;
        [$k, $v] = explode('=', $line, 2);
        $k = trim($k);
        $v = trim($v);
        // Strip single quotes added by save_cfg (e.g. GPU_NAME='...')
        if (strlen($v) >= 2 && $v[0] === "'" && $v[-1] === "'") {
            $v = str_replace("'\\''", "'", substr($v, 1, -1));
        }
        $cfg[$k] = $v;
    }
    return $cfg;
}

function save_cfg($cfg) {
    $dir = dirname(GOW_CFG);
    if (!is_dir($dir)) mkdir($dir, 0755, true);
    $out = '';
    foreach ($cfg as $k => $v) {
        // Single-quote values so bash can safely source this file even when
        // GPU_NAME contains spaces or brackets (e.g. "GeForce RTX 3060 LHR").
        $quoted = "'" . str_replace("'", "'\\''", $v) . "'";
        $out .= "$k=$quoted\n";
    }
    file_put_contents(GOW_CFG, $out);
}

// ── GPU detection ─────────────────────────────────────────────────────────────

function detect_gpus() {
    $gpus = [];
    $nodes = glob('/sys/class/drm/renderD*/device/driver') ?: [];
    foreach ($nodes as $driver_path) {
        $device_dir  = dirname($driver_path);
        $render_name = basename(dirname($device_dir));
        $render_node = "/dev/dri/{$render_name}";

        $driver = is_link($driver_path) ? basename(readlink($driver_path)) : 'unknown';
        $vendor_map = ['i915' => 'Intel', 'xe' => 'Intel', 'amdgpu' => 'AMD', 'nvidia' => 'NVIDIA'];
        $vendor = $vendor_map[$driver] ?? "Unknown ($driver)";

        $name = 'Unknown';
        $pci_slot = '';
        $real_path = realpath($device_dir);
        if ($real_path) $pci_slot = basename($real_path);
        if ($pci_slot) {
            $lspci_out = [];
            exec("lspci -s " . escapeshellarg($pci_slot) . " -mm 2>/dev/null", $lspci_out);
            if (!empty($lspci_out[0])) {
                // Format: "Slot" "Class" "Vendor" "Device" ...
                $parts = str_getcsv($lspci_out[0], ' ', '"');
                if (isset($parts[3])) $name = $parts[3];
            }
        }

        $gpus[] = [
            'node'   => $render_node,
            'driver' => $driver,
            'vendor' => $vendor,
            'name'   => $name,
            'label'  => "$vendor $name ($render_node)",
        ];
    }
    return $gpus;
}

// ── Container status ──────────────────────────────────────────────────────────

function container_status($name) {
    exec("docker inspect --format '{{.State.Status}}' " . escapeshellarg($name) . " 2>/dev/null", $out, $ret);
    return ($ret === 0 && !empty($out[0])) ? $out[0] : 'not found';
}

function status_badge($status) {
    $map = [
        'running'    => ['running',    '● Running'],
        'exited'     => ['stopped',    '● Stopped'],
        'restarting' => ['restarting', '● Restarting'],
        'not found'  => ['unknown',    '○ Not deployed'],
    ];
    [$cls, $label] = $map[$status] ?? ['unknown', "○ $status"];
    return "<span class='gow-status-{$cls}'>" . htmlspecialchars($label) . "</span>";
}

function local_ip() {
    exec("hostname -I 2>/dev/null", $out);
    return trim(explode(' ', $out[0] ?? '')[0]);
}

function docker_networks() {
    $networks = [];
    exec("docker network ls --format '{{.Name}}' 2>/dev/null", $out);
    foreach ($out as $name) {
        $name = trim($name);
        if ($name !== '' && preg_match('/^[A-Za-z0-9_.-]+$/', $name)) {
            $networks[] = $name;
        }
    }
    return array_values(array_unique($networks));
}

function valid_tcp_port($port) {
    return is_string($port) && preg_match('/^[0-9]+$/', $port)
        && (int)$port >= 1 && (int)$port <= 65535;
}

function cleanup_wolf_runtime_containers() {
    exec('docker rm -f WolfPulseAudio >/dev/null 2>&1 || true');
}

function valid_network_mode($mode) {
    return in_array($mode, ['host', 'bridge', 'custom'], true);
}

function valid_network_name($name) {
    return is_string($name) && preg_match('/^[A-Za-z0-9_.-]+$/', $name);
}

function valid_ipv4($ip) {
    if (!is_string($ip) || !preg_match('/^(\d{1,3}\.){3}\d{1,3}$/', $ip)) return false;
    foreach (explode('.', $ip) as $part) {
        if ((int)$part < 0 || (int)$part > 255 || (string)(int)$part !== (string)$part) return false;
    }
    return true;
}

// Wolf composes through Wayland; on NVIDIA this requires nvidia_drm.modeset=Y
// or the client gets a black screen. See docs/FAQ.md.
function nvidia_drm_modeset_ok() {
    $path = '/sys/module/nvidia_drm/parameters/modeset';
    if (!is_readable($path)) return false;
    return trim(@file_get_contents($path)) === 'Y';
}

function has_mdns_conflict() {
    exec("ss -H -ulpn 2>/dev/null", $out);
    $has_avahi = false;
    $has_wolf = false;
    foreach ($out as $line) {
        if (strpos($line, ':5353') === false) continue;
        if (strpos($line, 'avahi-daemon') !== false) $has_avahi = true;
        if (strpos($line, '"wolf"') !== false || strpos($line, 'users:((wolf,') !== false) $has_wolf = true;
    }
    return $has_avahi && $has_wolf;
}

define('FAQ_MODESET_URL', 'https://github.com/games-on-whales/unraid-plugin/blob/main/docs/FAQ.md#nvidia-wayland-support-nvidia_drmmodeset');
define('FAQ_MDNS_URL', 'https://github.com/games-on-whales/unraid-plugin/blob/main/docs/FAQ.md#moonlight-discovery-and-mdnsavahi-warnings');
define('WOLF_DEN_PAIRING_PATH', '/Clients/Pairing');

// ── Action handlers ───────────────────────────────────────────────────────────

$cfg     = load_cfg();
$message = '';
$error   = '';
$force_setup = false;

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $action = $_POST['action'] ?? '';

    if ($action === 'save_and_deploy') {
        // Validate and persist GPU selection + appdata path
        $cfg['RENDER_NODE'] = $_POST['render_node'] ?? '';
        $cfg['APPDATA']     = rtrim($_POST['appdata'] ?? DEFAULT_APPDATA, '/');
        $cfg['WOLF_DEN_PORT'] = trim($_POST['wolf_den_port'] ?? '8080');
        $cfg['WOLF_NETWORK_MODE'] = $_POST['wolf_network_mode'] ?? 'host';
        $cfg['WOLF_NETWORK_NAME'] = trim($_POST['wolf_network_name'] ?? '');
        $cfg['WOLF_NETWORK_IPV4'] = trim($_POST['wolf_network_ipv4'] ?? '');

        // Look up vendor/name/driver from the selected node
        $gpus = detect_gpus();
        foreach ($gpus as $gpu) {
            if ($gpu['node'] === $cfg['RENDER_NODE']) {
                $cfg['GPU_VENDOR'] = $gpu['vendor'];
                $cfg['GPU_NAME']   = $gpu['name'];
                $cfg['GPU_DRIVER'] = $gpu['driver'];
                break;
            }
        }

        if (empty($cfg['RENDER_NODE'])) {
            $error = 'Please select a GPU before installing.';
        } elseif (empty($cfg['GPU_VENDOR'])) {
            $error = 'Selected GPU not recognised. Please refresh and try again.';
        } elseif (!valid_tcp_port($cfg['WOLF_DEN_PORT'])) {
            $error = 'Wolf Den port must be a TCP port between 1 and 65535.';
        } elseif (!valid_network_mode($cfg['WOLF_NETWORK_MODE'])) {
            $error = 'Wolf network mode must be Host, Bridge, or Custom network.';
        } elseif ($cfg['WOLF_NETWORK_MODE'] === 'custom' && !valid_network_name($cfg['WOLF_NETWORK_NAME'])) {
            $error = 'Custom Wolf network requires a Docker network name such as br0.';
        } elseif ($cfg['WOLF_NETWORK_MODE'] === 'custom' && $cfg['WOLF_NETWORK_IPV4'] === '') {
            $error = 'Custom Wolf network requires a static IPv4 address.';
        } elseif ($cfg['WOLF_NETWORK_MODE'] === 'custom' && !valid_ipv4($cfg['WOLF_NETWORK_IPV4'])) {
            $error = 'Wolf static IPv4 address is invalid.';
        } else {
            save_cfg($cfg);
            // Run deploy in background; stream to log file.
            // Use < /dev/null to fully detach stdin so PHP's exec() returns
            // immediately instead of blocking until the child exits.
            exec('bash ' . GOW_SCRIPT_DIR . '/deploy.sh > ' . DEPLOY_LOG . ' 2>&1 < /dev/null &');
            // Use JavaScript redirect — PHP header() can be unreliable inside
            // Unraid's plugin framework when headers have already been sent.
            echo '<script>window.location.href = window.location.pathname + "?deploying=1";</script>';
            exit;
        }
        $force_setup = true;

    } elseif ($action === 'start') {
        $compose = $cfg['APPDATA'] . '/docker-compose.yml';
        if (file_exists($compose)) {
            exec("docker compose -f " . escapeshellarg($compose) . " up -d 2>&1", $out, $ret);
        } else {
            exec("docker start wolf wolf-den 2>&1", $out, $ret);
        }
        $message = $ret === 0 ? 'Wolf started.' : 'Start failed: ' . implode("\n", $out);

    } elseif ($action === 'stop') {
        $compose = $cfg['APPDATA'] . '/docker-compose.yml';
        if (file_exists($compose)) {
            exec("docker compose -f " . escapeshellarg($compose) . " down 2>&1", $out, $ret);
        } else {
            exec("docker stop wolf-den wolf 2>&1", $out, $ret);
        }
        cleanup_wolf_runtime_containers();
        $message = $ret === 0 ? 'Wolf stopped.' : 'Stop failed: ' . implode("\n", $out);

    } elseif ($action === 'update') {
        exec('bash ' . GOW_SCRIPT_DIR . '/update.sh 2>&1', $out, $ret);
        $message = $ret === 0 ? 'Update complete.' : 'Update failed: ' . implode("\n", $out);

    } elseif ($action === 'reconfigure') {
        $cfg['DEPLOYED'] = 'false';
        save_cfg($cfg);
        echo '<script>window.location.href = window.location.pathname + "?setup=1";</script>';
        exit;
    }
}

// Detect if a deploy is in progress
$deploying = isset($_GET['deploying']);
if ($deploying) {
    // Check if deploy.sh is still running
    exec("pgrep -f deploy.sh", $pids);
    if (empty($pids)) {
        // Reload cfg — DEPLOYED may now be true
        $cfg = load_cfg();
        $deploying = false;
    }
}

$gpus            = detect_gpus();
$docker_networks = docker_networks();
$ip              = local_ip();
$wolf_status     = container_status('wolf');
$wolf_den_status = container_status('wolf-den');
$compose_file    = $cfg['APPDATA'] . '/docker-compose.yml';
$has_stack       = file_exists($compose_file) || $wolf_status !== 'not found' || $wolf_den_status !== 'not found';
$setup_mode      = $force_setup || isset($_GET['setup']);
$deployed        = !$setup_mode && (($cfg['DEPLOYED'] === 'true') || $has_stack);
$wolf_den_port   = valid_tcp_port($cfg['WOLF_DEN_PORT']) ? $cfg['WOLF_DEN_PORT'] : '8080';
$wolf_den_url    = $ip ? "http://{$ip}:{$wolf_den_port}" : '';
$pairing_url     = $wolf_den_url ? $wolf_den_url . WOLF_DEN_PAIRING_PATH : '';
$wolf_network_mode = valid_network_mode($cfg['WOLF_NETWORK_MODE']) ? $cfg['WOLF_NETWORK_MODE'] : 'host';
$wolf_network_name = $cfg['WOLF_NETWORK_NAME'];
$wolf_network_ipv4 = $cfg['WOLF_NETWORK_IPV4'];
$moonlight_host    = ($wolf_network_mode === 'custom' && valid_ipv4($wolf_network_ipv4)) ? $wolf_network_ipv4 : $ip;
$mdns_conflict   = $deployed && has_mdns_conflict();
?>

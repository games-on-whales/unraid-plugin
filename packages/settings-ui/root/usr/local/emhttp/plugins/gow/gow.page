<script>
(() => {
  const card = document.getElementById('gow-progress-card');
  if (!card) return;
  const action = card.getAttribute('data-log-action') || 'deploy';
  const logEl = document.getElementById('gow-progress-log');
  const statusEl = document.getElementById('gow-progress-status');
  const pollUrl = <?= json_encode(LOGS_URL) ?> + '?action=' + encodeURIComponent(action);
  const pollMs = 2000;
  let stallTicks = 0;
  let lastText = logEl ? logEl.textContent : '';

  const scrollLog = () => {
    if (logEl) logEl.scrollTop = logEl.scrollHeight;
  };

  const poll = () => {
    fetch(pollUrl, { cache: 'no-store', credentials: 'same-origin' })
      .then((r) => r.json())
      .then((data) => {
        if (logEl && typeof data.text === 'string') {
          logEl.textContent = data.text || 'Waiting for output…\n';
          scrollLog();
          if (data.text === lastText) {
            stallTicks += 1;
          } else {
            stallTicks = 0;
            lastText = data.text;
          }
        }
        if (data.active) {
          if (statusEl && stallTicks >= 8) {
            statusEl.textContent = 'Still working — large steps (permissions, image pull, or NVIDIA driver build) can take several minutes with little new output.';
          }
          setTimeout(poll, pollMs);
          return;
        }
        if (statusEl) {
          statusEl.textContent = 'Finished — loading dashboard…';
        }
        const failed = (data.text || '').indexOf('ERROR:') !== -1;
        const target = window.location.pathname
          + (failed ? '?setup=1&deploy_error=1' : '?welcome=1');
        window.setTimeout(() => { window.location.href = target; }, 800);
      })
      .catch(() => setTimeout(poll, pollMs + 1000));
  };

  scrollLog();
  setTimeout(poll, 800);
})();

(() => {
  const logEl = document.getElementById('gow-live-log');
  const logPanel = document.getElementById('gow-logs-panel');
  if (logEl && logPanel) {
    const sourceEl = document.getElementById('gow-log-source');
    const linesEl = document.getElementById('gow-log-lines');
    const followEl = document.getElementById('gow-log-follow');
    const refreshBtn = document.getElementById('gow-log-refresh');
    const logsUrl = <?= json_encode(LOGS_URL) ?>;
    const pollMs = 3000;
    let timer = null;

    const scrollIfFollow = (wasAtBottom) => {
      if (followEl && followEl.checked && wasAtBottom) {
        logEl.scrollTop = logEl.scrollHeight;
      }
    };

    const fetchLogs = async () => {
      const src = sourceEl ? sourceEl.value : 'tail:wolf';
      let url;
      if (src.startsWith('tail:')) {
        const container = src.slice(5);
        const lines = linesEl ? Math.min(500, Math.max(50, parseInt(linesEl.value, 10) || 150)) : 150;
        url = `${logsUrl}?action=tail&container=${encodeURIComponent(container)}&lines=${lines}`;
      } else {
        url = `${logsUrl}?action=${encodeURIComponent(src)}`;
      }
      const wasAtBottom = logEl.scrollHeight - logEl.scrollTop - logEl.clientHeight < 48;
      try {
        const resp = await fetch(url, { cache: 'no-store', credentials: 'same-origin' });
        const data = await resp.json();
        logEl.classList.remove('gow-log-empty');
        if (data.error) {
          logEl.textContent = data.error;
          return;
        }
        let text = (data.text && String(data.text).trim() !== '') ? data.text : '(no output yet)';
        if (src.startsWith('tail:') && data.running === false) {
          text += '\n\n(container is not running or has no logs yet)';
        }
        if (!src.startsWith('tail:') && data.active) {
          text += '\n\n(in progress…)';
        }
        logEl.textContent = text;
        scrollIfFollow(wasAtBottom);
      } catch (err) {
        logEl.classList.remove('gow-log-empty');
        logEl.textContent = 'Could not load logs. Check that Docker is running.';
      }
    };

    const stopPoll = () => {
      if (timer !== null) {
        clearInterval(timer);
        timer = null;
      }
    };

    const startPoll = () => {
      stopPoll();
      fetchLogs();
      timer = setInterval(fetchLogs, pollMs);
    };

    if (sourceEl) sourceEl.addEventListener('change', startPoll);
    if (linesEl) linesEl.addEventListener('change', fetchLogs);
    if (refreshBtn) refreshBtn.addEventListener('click', fetchLogs);
    if (followEl) {
      followEl.addEventListener('change', () => {
        if (followEl.checked) logEl.scrollTop = logEl.scrollHeight;
      });
    }

    logPanel.addEventListener('toggle', () => {
      if (logPanel.open) {
        startPoll();
      } else {
        stopPoll();
        logEl.textContent = 'Open this panel to load logs…';
        logEl.classList.add('gow-log-empty');
      }
    });

    if (logPanel.open) {
      startPoll();
    }
  }

  const mode = document.getElementById('wolf_network_mode');
  const networkDetails = document.getElementById('gow-network-details');
  const customRows = document.querySelectorAll('.gow-network-custom');
  if (mode) {
    const syncNetworkFields = () => {
      const show = mode.value === 'custom';
      customRows.forEach(row => { row.style.display = show ? 'flex' : 'none'; });
      if (show && networkDetails) networkDetails.open = true;
    };
    mode.addEventListener('change', syncNetworkFields);
    syncNetworkFields();
  }
})();

(function () {
  const FILETREE_SCRIPTS = [
    '/webGui/scripts/jquery.filetree.js',
    '/plugins/dynamix/javascript/jquery.filetree.js',
  ];

  function gowLoadFileTree(done) {
    if (window.jQuery && jQuery.fn && jQuery.fn.fileTreeAttach) {
      done();
      return;
    }
    const pending = document.querySelector('script[data-gow-filetree-loader]');
    if (pending) {
      pending.addEventListener('load', () => done(), { once: true });
      pending.addEventListener('error', () => done(), { once: true });
      return;
    }
    let idx = 0;
    const tryNext = () => {
      if (window.jQuery && jQuery.fn && jQuery.fn.fileTreeAttach) {
        done();
        return;
      }
      if (idx >= FILETREE_SCRIPTS.length) {
        console.warn('GoW: jquery.filetree.js not available — folder browse disabled');
        done();
        return;
      }
      const script = document.createElement('script');
      script.src = FILETREE_SCRIPTS[idx++];
      script.dataset.gowFiletreeLoader = '1';
      script.onload = () => tryNext();
      script.onerror = () => tryNext();
      document.head.appendChild(script);
    };
    tryNext();
  }

  function gowInitShareSelects(root) {
    (root || document).querySelectorAll('.gow-share-select').forEach((select) => {
      if (select.dataset.gowShareBound) return;
      select.dataset.gowShareBound = '1';
      select.addEventListener('change', () => {
        const path = select.value;
        if (!path) return;
        const input = document.getElementById(select.dataset.target || '');
        if (input) {
          input.value = path;
          input.dispatchEvent(new Event('change', { bubbles: true }));
        }
        select.selectedIndex = 0;
      });
    });
  }

  function gowInitPathPickers(root) {
    if (!window.jQuery || !jQuery.fn || !jQuery.fn.fileTreeAttach) return;
    jQuery(root || document).find('input.gow-path-picker').each(function () {
      const $input = jQuery(this);
      if ($input.data('gowFileTree')) return;
      $input.fileTreeAttach(null, null, function (folder) {
        $input.val(folder).trigger('change');
        jQuery(document).trigger('close.fileTree');
      });
      $input.data('gowFileTree', true);
    });
  }

  function gowInitPathControls(root) {
    gowInitShareSelects(root);
    gowLoadFileTree(() => gowInitPathPickers(root));
  }

  jQuery(function () {
    gowInitPathControls(document);

    document.querySelectorAll('.gow-browse-btn').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const input = document.getElementById(btn.getAttribute('data-target') || '');
        if (!input) return;
        gowLoadFileTree(() => {
          gowInitPathPickers(input.closest('.gow-field') || document);
          input.focus();
          input.click();
        });
      });
    });

    document.querySelectorAll('details.gow-details').forEach((panel) => {
      panel.addEventListener('toggle', () => {
        if (panel.open) gowInitPathControls(panel);
      });
    });
  });
})();
</script>
